# FraudGuard AI — Environment Variables
#
# Copy this file to .env.local for local development.
# Set these in Vercel project settings → Environment Variables for deployment.
# NEVER commit .env.local or real credentials to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Neon or Supabase free Postgres) ─────────────────────────────────
# Get from: https://neon.tech (Neon free tier) or https://supabase.com (Supabase free tier)
# Format: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/fraudguard?sslmode=require

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Get from: https://upstash.com → Create Database → REST API section
# Free tier: 10,000 commands/day, no credit card required
UPSTASH_REDIS_REST_URL=https://xxxx-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxxxxxxxxxxxxxxxxxx

# ── NextAuth.js ───────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET: generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-super-secret-nextauth-key-change-this
NEXTAUTH_URL=http://localhost:3000
# In production: NEXTAUTH_URL=https://your-app.vercel.app

# ── Analyst Credentials (credentials provider) ────────────────────────────────
# ADMIN: full access (can whitelist/blacklist, configure thresholds)
ADMIN_EMAIL=admin@fraudguard.ai
ADMIN_PASSWORD=change-this-strong-password

# ANALYST: can approve/decline/escalate REVIEW transactions
ANALYST_EMAIL=analyst@fraudguard.ai
ANALYST_PASSWORD=change-this-analyst-password

# VIEWER: read-only dashboard access
VIEWER_EMAIL=viewer@fraudguard.ai
VIEWER_PASSWORD=change-this-viewer-password

# ── Webhook HMAC Secret ────────────────────────────────────────────────────────
# Used to verify signatures on POST /api/ingest requests from PSPs.
# Generate with: openssl rand -hex 32
# Share this secret with your PSP/payment service.
WEBHOOK_HMAC_SECRET=your-webhook-hmac-secret-hex-string

# ── Identifier Hashing ────────────────────────────────────────────────────────
# Server-side pepper for SHA-256 hashing of PAN/VPA/account identifiers.
# This prevents reversing hashes even if the DB is compromised.
# Generate with: openssl rand -hex 32
SERVER_PEPPER=your-server-side-pepper-hex-string

# ── Rate Limiting (optional overrides) ───────────────────────────────────────
# Sliding window configuration for POST /api/score rate limiter.
# Defaults: 30 requests per 60 seconds.
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────────────────────────────────────
# Setup Checklist:
# 1. Create Neon account at neon.tech → create "fraudguard" database → copy DATABASE_URL
# 2. Run: npx prisma migrate deploy (to create tables)
# 3. Create Upstash account at upstash.com → create Redis database → copy URL + token
# 4. Generate NEXTAUTH_SECRET: openssl rand -base64 32
# 5. Set strong credentials for ADMIN_EMAIL, ADMIN_PASSWORD, etc.
# 6. Generate WEBHOOK_HMAC_SECRET: openssl rand -hex 32
# 7. Generate SERVER_PEPPER: openssl rand -hex 32
# 8. Add all vars to Vercel: Settings → Environment Variables
# 9. Run: vercel deploy --prod
# ─────────────────────────────────────────────────────────────────────────────
