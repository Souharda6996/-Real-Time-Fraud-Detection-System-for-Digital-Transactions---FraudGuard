{
  "version": "2.0",
  "model_type": "gradient_boosted_trees",
  "trained_on": "Kaggle Credit Card Fraud Detection (284,807 transactions, 492 frauds) + PaySim TRANSFER/CASH_OUT subset (1.58M transactions). Run model-training/train_gbm.py to reproduce.",
