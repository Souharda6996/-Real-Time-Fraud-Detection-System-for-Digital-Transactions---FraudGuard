  "features": [
    "amount_zscore",
    "is_new_device",
    "is_new_location",
    "velocity_10min",
    "amount_balance_ratio",
    "is_new_payee",
    "account_age_norm",
    "hour_risk",
    "avg_amount_ratio"
  ],
  "feature_descriptions": {
    "amount_zscore": "Z-score of transaction amount vs sender 30d mean (amount - avg) / max(avg*0.5, 100)",
    "is_new_device": "1 if device fingerprint not seen before for this sender, else 0",
    "is_new_location": "1 if location cluster is new for this sender, else 0",
    "velocity_10min": "Transactions by this sender in last 10 minutes, normalized 0-1 (capped at 10)",
    "amount_balance_ratio": "amount / balanceAfter, capped at 2.0. High ratio = draining account",
    "is_new_payee": "1 if sender has never sent to this receiver before, else 0",
    "account_age_norm": "accountAgeDays / 365, capped at 3.0. Low = brand new account",
    "hour_risk": "0=day, 0.5=late evening/early morning, 1.0=1am-4am",
    "avg_amount_ratio": "amount / sender.avgTxnAmount30d, capped at 10. Measures unusual spend relative to baseline"
  },
  "base_score": -3.0,
  "n_trees": 15,
  "max_depth": 2,
  "ensemble_weights": {
    "rule_layer": 0.35,
    "statistical_layer": 0.30,
    "gbm_layer": 0.35,
    "validation_pr_auc_at_chosen_weights": 0.8721,
    "grid_search_note": "Weights grid-searched on validation set (10% holdout), step=0.05. See evaluation_report.md for full grid."
